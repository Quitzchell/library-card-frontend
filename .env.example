# Backend API URL (server-side, preferred in production)
# Production: https://your-backend.onrender.com/api
BACKEND_URL=

# Browser-facing API URL (used by client components, fallback for server when BACKEND_URL is unset)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Media base URL for images (used in next.config.ts remotePatterns)
# Production: https://your-backend.onrender.com
NEXT_PUBLIC_MEDIA_URL=http://localhost:8080

# Which API to use: mock | django | laravel
NEXT_PUBLIC_USE_API=laravel

# Supabase URL (for image remotePatterns in production)
# Production: https://xxx.supabase.co
SUPABASE_URL=

# ISR revalidation interval in seconds (default: 86400 = 24 hours)
REVALIDATE_SECONDS=86400

# Secret for on-demand revalidation webhook
# Must match the value the backend sends in the x-revalidation-secret header
REVALIDATION_SECRET=

# Secret for the Vercel Cron warm-cache GET endpoint
# Sent as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Upstash Redis (Vercel KV) — persistent cache for when the backend is offline
# Create a store at https://console.upstash.com or via the Vercel integration
KV_REST_API_URL=
KV_REST_API_TOKEN=