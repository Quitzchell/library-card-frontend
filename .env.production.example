# library-card frontend — production env (Hetzner: Docker + Caddy)
#
# Two roles, on purpose:
#   • BUILD-TIME (baked into the JS): NEXT_PUBLIC_* → must be PUBLIC URLs
#   • RUNTIME (server-side only):     BACKEND_URL + secrets → internal/private
#
# Deploy: docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# ── Runtime: server-side API path (internal Docker network, never public) ──
# Points at the Laravel API container by name on the shared Caddy network.
BACKEND_URL=http://library-card-api:80/api

# ── Build-time: browser-facing, PUBLIC https URLs ──
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api
# Media is served by the backend from local disk at APP_URL/storage/...,
# so this is the same host as the API (without the /api path).
NEXT_PUBLIC_MEDIA_URL=https://api.yourdomain.com
NEXT_PUBLIC_USE_API=laravel

# ── ISR ──
REVALIDATE_SECONDS=86400

# ── Secret: must match the x-revalidation-secret the Laravel backend sends ──
REVALIDATION_SECRET=